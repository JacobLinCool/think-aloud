    "Used to push the dataset from the browser window. Token is stored in macOS Keychain.": {
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在瀏覽器視窗用來推送資料集。Token 儲存於 macOS Keychain。"
          }
        }
      }
    },
    "View insights": {
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "查看統計"
          }
        }
      }
    },
    "Voice Veteran": {
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "口述老手"
          }
        }
      }
    },
    "Warmed Up": {
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "熱身完成"
          }
        }
      }
    },
    "We compare the time it would take to **type** your final text against the time you actually spent **speaking**, minus the time spent fixing the transcript.": {
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我們以**打出**最終文字所需的時間，對比你實際**口述**的時間，再扣除修正逐字稿的時間。"
          }
        }
      }
    },
    "Weeklong": {
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "持續一週"
          }
        }
      }
    },
    "Welcome to ThinkAloud": {
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "歡迎使用 ThinkAloud"
          }
        }
      }
    },
    "Where you dictate": {
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你在哪裡口述"
          }
        }
      }
