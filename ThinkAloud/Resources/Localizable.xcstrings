          "stringUnit": {
            "state": "translated",
            "value": "設定完成"
          }
        }
      }
    },
    "Your current mode is Off, so no recording is cleaned. Switch to Auto or On to use this.": {
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你目前的模式是「關閉」,因此不會清理任何錄音。切換到「自動」或「開啟」才會作用。"
          }
        }
      }
    },
    "Your current mode is On, so every recording is cleaned regardless.": {
